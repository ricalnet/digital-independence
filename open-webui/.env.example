# ============================================
# KONFIGURASI DASAR
# ============================================

# Generate key: openssl rand -hex 32
WEBUI_SECRET_KEY=

# Domain
DOMAIN=localhost
WEBUI_URL=http://localhost:3000

# HF Token (optional, untuk akses model dari HuggingFace)
# HF_TOKEN=hf_xxx

# Logging
LOG_LEVEL=info
MAX_LOG_SIZE=10m
MAX_LOG_FILES=3

# ============================================
# KONFIGURASI OLLAMA (PILIH SALAH SATU)
# ============================================

# [MODE 1] - Jika Ollama berjalan dalam docker-compose (service ollama di-uncomment)
# OLLAMA_BASE_URL=http://ollama:11434

# [MODE 2] - Jika Ollama berjalan di host/local (tanpa service ollama di compose)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# [MODE 3] - Jika Ollama berjalan di server eksternal/IP lain
# OLLAMA_BASE_URL=http://192.168.1.100:11434

# Default: Gunakan mode 1 (uncomment yang sesuai kebutuhan)
OLLAMA_BASE_URL=http://ollama:11434

# ============================================
# KONFIGURASI OLLAMA (hanya untuk service ollama)
# ============================================
OLLAMA_HOST=0.0.0.0
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_THREADS=2
OLLAMA_GPU_OVERHEAD=0