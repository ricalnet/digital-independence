# ============================================
# BASIC CONFIGURATION
# ============================================

# Generate key: openssl rand -hex 32
WEBUI_SECRET_KEY=

# Domain
DOMAIN=localhost
WEBUI_URL=http://localhost:3000

# HF Token (optional, for accessing models from HuggingFace)
# HF_TOKEN=hf_xxx

# Logging
LOG_LEVEL=info
MAX_LOG_SIZE=10m
MAX_LOG_FILES=3

# ============================================
# OLLAMA CONFIGURATION (CHOOSE ONE)
# ============================================

# [MODE 1] - If Ollama is running in docker-compose (uncomment ollama service)
# OLLAMA_BASE_URL=http://ollama:11434

# [MODE 2] - If Ollama is running on host/local (without ollama service in compose)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# [MODE 3] - If Ollama is running on external server/other IP
# OLLAMA_BASE_URL=http://192.168.1.100:11434

# Default: Use mode 1 (uncomment the appropriate one based on your needs)
OLLAMA_BASE_URL=http://ollama:11434

# ============================================
# OLLAMA CONFIGURATION (for ollama service only)
# ============================================
OLLAMA_HOST=0.0.0.0
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_THREADS=2
OLLAMA_GPU_OVERHEAD=0