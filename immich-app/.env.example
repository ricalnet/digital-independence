# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored. Network shares are not supported for the database
DB_DATA_LOCATION=./postgres

# Timezone configuration - uncomment to set a specific timezone
# Format: TZ=Region/City (e.g., TZ=Asia/Jakarta for Indonesia)
# Reference: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
# TZ=Etc/UTC

# Immich version specification - pin to specific version if needed
# Format: vX.Y.Z (e.g., v2.1.0) or use "v3" for latest stable
IMMICH_VERSION=v3

# PostgreSQL database password - change this to a secure random password
# Restrictions: Only alphanumeric characters (A-Z, a-z, 0-9) are allowed
# No special characters or spaces
DB_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# PostgreSQL database settings - these values should not be modified
# Database username
DB_USERNAME=postgres
# Database name for Immich
DB_DATABASE_NAME=immich