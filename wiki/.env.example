# MediaWiki Configuration
MEDIAWIKI_VERSION=latest
MEDIAWIKI_CONTAINER_NAME=mediawiki
MEDIAWIKI_HOST=127.0.0.1
MEDIAWIKI_PORT=8002
MEDIAWIKI_IMAGES_PATH=./mediawiki_data
MEDIAWIKI_VOLUME_NAME=mediawiki_data

# Database Configuration
DB_IMAGE=mariadb
DB_VERSION=latest
DB_CONTAINER_NAME=mediawiki_db
DB_HOST=db
DB_HOST_BIND=127.0.0.1
DB_PORT_BIND=3307
DB_DATA_PATH=./db_data
DB_VOLUME_NAME=db_data

# MySQL/MariaDB Credentials
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=mediawiki
MYSQL_USER=mediawiki
MYSQL_PASSWORD=CHANGE_ME_MEDIAWIKI_PASSWORD

# LocalSettings.php (uncomment in docker-compose.yml after installation)
# LOCALSETTINGS_PATH=./LocalSettings.php

# Restart Policy
RESTART_POLICY=unless-stopped