# ============================================
# TIME ZONE
# ============================================
TZ=Asia/Jakarta

# ============================================
# AUTHENTICATION
# ============================================
FTLCONF_webserver_api_password=YourStrongPassword123!
WEBPASSWORD=YourStrongPassword123!

# ============================================
# DNSCRYPT-PROXY CONFIGURATION
# ============================================
DNSCRYPT_UPSTREAM_SERVERS="['9.9.9.9:53', '149.112.112.112:53']"
DNSCRYPT_FALLBACK_RESOLVER="9.9.9.9:53"
DNSCRYPT_IGNORE_SYSTEM_DNS=true
DNSCRYPT_NETLOG_FILE="/var/log/dnscrypt-proxy.log"
DNSCRYPT_LOG_LEVEL=0
DNSCRYPT_USE_SYSLOG=true
DNSCRYPT_CACHE_SIZE=20000
DNSCRYPT_CACHE_MIN_TTL=600
DNSCRYPT_CACHE_MAX_TTL=86400
DNSCRYPT_CACHE_NEGATIVE_MIN_TTL=60
DNSCRYPT_CACHE_NEGATIVE_MAX_TTL=1800
DNSCRYPT_PREFER_IPV6=false
DNSCRYPT_EDNS_PAYLOAD_SIZE=1452
DNSCRYPT_TIMEOUT=5000
DNSCRYPT_KEEPALIVE=30
DNSCRYPT_QUERY_LOG_FILE="/dev/null"
DNSCRYPT_QUERY_LOG_FORMAT="tsv"
DNSCRYPT_FORCE_TCP=false
DNSCRYPT_BLOCK_IPV6=false

# ============================================
# PI-HOLE DNS CONFIGURATION
# ============================================
FTLCONF_dns_upstreams=dnscrypt-proxy#5053
FTLCONF_dns_blockESNI=true
FTLCONF_dns_EDNS0ECS=false
FTLCONF_dns_ignoreLocalhost=true
FTLCONF_dns_showDNSSEC=true
FTLCONF_dns_analyzeOnlyAandAAAA=false
FTLCONF_dns_piholePTR=pi.hole
FTLCONF_dns_replyWhenBusy=BLOCK
FTLCONF_dns_blockTTL=86400
FTLCONF_dns_domainNeeded=true
FTLCONF_dns_expandHosts=false
FTLCONF_dns_bogusPriv=true
FTLCONF_dns_dnssec=true
FTLCONF_dns_interface=
FTLCONF_dns_listeningMode=ALL
FTLCONF_dns_queryLogging=false
FTLCONF_dns_port=53
FTLCONF_dns_localise=false

# ============================================
# PI-HOLE CACHE
# ============================================
FTLCONF_dns_cache_size=10000
FTLCONF_dns_cache_optimizer=7200
FTLCONF_dns_cache_upstreamBlockedTTL=86400

# ============================================
# PI-HOLE BLOCKING
# ============================================
FTLCONF_dns_blocking_active=true

# ============================================
# RATE LIMITING
# ============================================
FTLCONF_dns_rateLimit_count=2000
FTLCONF_dns_rateLimit_interval=60

# ============================================
# DATABASE
# ============================================
FTLCONF_database_maxDBdays=7
FTLCONF_database_network_expire=7

# ============================================
# PRIVACY
# ============================================
FTLCONF_misc_privacylevel=3