# Homarr Environment Configuration
# =================================

# Secret encryption key for securing sensitive data
# Generate a strong key using: openssl rand -base64 32
# Or use: tr -dc 'a-zA-Z0-9' < /dev/urandom | fold -w 32 | head -n 1
SECRET_ENCRYPTION_KEY=

# Optional: Database configuration (if using external database)
# DATABASE_URL=postgresql://user:password@host:5432/homarr

# Optional: Redis configuration (if using Redis for caching)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Optional: OAuth/OIDC configuration
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_ISSUER=

# Optional: Email configuration (for notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
